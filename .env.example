# Local-only mode (this repo)
LOCAL_MODE=true
NEXT_PUBLIC_LOCAL_MODE=true

# Optional: override local storage root (default: ~/.manimate)
# MANIMATE_LOCAL_ROOT=/absolute/path/to/.manimate

# Optional: ElevenLabs voice lookup/voiceover features
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=Lci8YeL6PAFHJjNKvwXq  # defaults to Yusuke if unset

# Optional: app URL used in some client links
# NEXT_PUBLIC_APP_URL=http://localhost:3000
